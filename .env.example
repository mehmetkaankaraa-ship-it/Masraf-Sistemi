# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (Neon PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
# DATABASE_URL  → connection-pooler URL  (used by the app at runtime)
# DIRECT_URL    → direct (non-pooled) URL (used by Prisma migrations & Studio)
#
# Get both from: Neon Console → your project → Connection Details
# Make sure to copy the "Pooled" URL for DATABASE_URL.
DATABASE_URL="postgresql://neondb_owner:<password>@ep-<name>-pooler.<region>.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:<password>@ep-<name>.<region>.aws.neon.tech/neondb?sslmode=require"

# ─────────────────────────────────────────────────────────────────────────────
# NextAuth v5
# ─────────────────────────────────────────────────────────────────────────────
# AUTH_SECRET (preferred name in v5) / NEXTAUTH_SECRET (backwards-compat) —
# generate a strong random value:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
# Keep NEXTAUTH_SECRET as a copy so older tooling still works:
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"

# AUTH_URL / NEXTAUTH_URL — the canonical URL of the app.
# On Vercel this is auto-detected; set it anyway for safety.
# Local:
NEXTAUTH_URL="http://localhost:3000"
# Production (uncomment and fill in):
# AUTH_URL="https://your-app.vercel.app"
# NEXTAUTH_URL="https://your-app.vercel.app"

# ─────────────────────────────────────────────────────────────────────────────
# File uploads
# ─────────────────────────────────────────────────────────────────────────────
# Local dev — files are stored in ./uploads
UPLOAD_DIR="./uploads"
# Production — switch to S3:
# AWS_BUCKET=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
